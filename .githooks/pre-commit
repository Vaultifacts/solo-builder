#!/usr/bin/env bash
if command -v pwsh >/dev/null 2>&1; then
  pwsh tools/dev_gate.ps1 -Mode PreCommit
else
  powershell -ExecutionPolicy Bypass -File tools/dev_gate.ps1 -Mode PreCommit
fi
if [ $? -ne 0 ]; then exit 1; fi

if command -v node >/dev/null 2>&1; then
  node tools/lint_dashboard_handlers.js
  if [ $? -ne 0 ]; then exit 1; fi
fi
