# Solo Builder — environment variables
# Copy this file to .env (never committed) and fill in your values.

# Required for real Claude outputs (SDK runner + SdkToolRunner)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults come from config/settings.json)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=512

# Discord bot (discord_bot/bot.py)
# DISCORD_BOT_TOKEN=<token from discord.com/developers/applications>
# DISCORD_CHANNEL_ID=<channel ID — optional, restricts bot to one channel>
